{
  "name": "pittacusw/touchef",
  "description": "Wrapper to connect a Laravel application to the Touchef API",
  "keywords": [
    "laravel",
    "touchef",
    "sii",
    "dte",
    "facturacion-electronica",
    "chile"
  ],
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Touchef",
      "email": "contacto@touchef.cl"
    }
  ],
  "require": {
    "php": " ^8.1",
    "laravel/framework": "^13.0",
    "freshwork/chilean-bundle": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Pittacusw\\Touchef\\": "src/Pittacusw/Touchef/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Pittacusw\\Touchef\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "orchestra/testbench": "^7.0|^10.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pittacusw\\Touchef\\TouchefServiceProvider"
      ],
      "aliases": {
        "Touchef": "Pittacusw\\Touchef\\TouchefFacade"
      }
    }
  }
}
